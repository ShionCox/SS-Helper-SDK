{
  "name": "@ss-helper/sdk",
  "version": "2.0.0",
  "description": "Stateless public contracts for SS-Helper plugins",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js" },
    "./server": { "types": "./dist/server.d.ts", "node": "./dist/server.js", "import": "./dist/server.js", "default": "./dist/server.js" },
    "./contracts/core": { "types": "./dist/contracts/core.d.ts", "import": "./dist/contracts/core.js", "default": "./dist/contracts/core.js" },
    "./contracts/plugin": { "types": "./dist/contracts/plugin.d.ts", "import": "./dist/contracts/plugin.js", "default": "./dist/contracts/plugin.js" },
    "./contracts/services": { "types": "./dist/contracts/services.d.ts", "import": "./dist/contracts/services.js", "default": "./dist/contracts/services.js" },
    "./contracts/events": { "types": "./dist/contracts/events.d.ts", "import": "./dist/contracts/events.js", "default": "./dist/contracts/events.js" },
    "./contracts/settings": { "types": "./dist/contracts/settings.d.ts", "import": "./dist/contracts/settings.js", "default": "./dist/contracts/settings.js" },
    "./contracts/ui": { "types": "./dist/contracts/ui.d.ts", "import": "./dist/contracts/ui.js", "default": "./dist/contracts/ui.js" },
    "./contracts/host": { "types": "./dist/contracts/host.d.ts", "import": "./dist/contracts/host.js", "default": "./dist/contracts/host.js" },
    "./contracts/llm": { "types": "./dist/contracts/llm.d.ts", "import": "./dist/contracts/llm.js", "default": "./dist/contracts/llm.js" },
    "./contracts/memory": { "types": "./dist/contracts/memory.d.ts", "import": "./dist/contracts/memory.js", "default": "./dist/contracts/memory.js" },
    "./contracts/workspace": { "types": "./dist/contracts/workspace.d.ts", "import": "./dist/contracts/workspace.js", "default": "./dist/contracts/workspace.js" },
    "./errors": { "types": "./dist/errors.d.ts", "import": "./dist/errors.js", "default": "./dist/errors.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": { "node": ">=20" },
  "license": "UNLICENSED"
}
