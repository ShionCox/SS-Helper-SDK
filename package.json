{
  "name": "ss-helper-sdk-workspace",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "node scripts/generate-icons.mjs --check && pnpm --filter @ss-helper/core-extension build",
    "build:sdk": "pnpm --filter @ss-helper/sdk build",
    "typecheck": "pnpm build:sdk && pnpm -r typecheck && pnpm test:types",
    "lint": "pnpm -r lint && node scripts/lint-boundaries.mjs",
    "test": "pnpm build:sdk && pnpm build:core && node --test tests/*.test.mjs && pnpm test:types",
    "test:types": "node scripts/verify-type-fixtures.mjs",
    "pack:sdk": "node scripts/pack-sdk.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "artifact:gate": "node scripts/artifact-gate.mjs",
    "verify:docs": "node scripts/verify-doc-links.mjs",
    "legacy:scan": "node scripts/legacy-scan.mjs --sdk-root ."
  },
  "devDependencies": {
    "@ss-helper/sdk": "workspace:*",
    "typescript": "5.9.2"
  }
}
